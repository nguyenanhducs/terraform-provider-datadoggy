[
  {
    "type": "notebook_cells",
    "attributes": {
      "definition": {
        "type": "iframe",
        "url": "https://example.com/dashboard"
      },
      "graph_size": "xl"
    }
  },
  {
    "type": "notebook_cells",
    "attributes": {
      "definition": {
        "type": "manage_status",
        "query": "service:$service",
        "sort": "status,asc",
        "count": 50,
        "start": 0,
        "display_format": "countsAndList",
        "color_preference": "text",
        "hide_zero_counts": true,
        "show_last_triggered": false,
        "summary_type": "combined",
        "show_priority": true,
        "title": "Service Status",
        "title_size": "16",
        "title_align": "left"
      },
      "graph_size": "xl"
    }
  },
  {
    "type": "notebook_cells",
    "attributes": {
      "definition": {
        "type": "markdown",
        "text": "# Overview\n\nThis notebook provides an overview of the service."
      }
    }
  },
  {
    "type": "notebook_cells",
    "attributes": {
      "definition": {
        "type": "timeseries",
        "requests": [
          {
            "display_type": "line",
            "queries": [
              {
                "name": "query1",
                "data_source": "metrics",
                "query": "avg:system.cpu.user{$env} by {host}"
              }
            ],
            "response_format": "timeseries",
            "style": {
              "palette": "dog_classic",
              "line_type": "solid",
              "line_width": "normal"
            }
          }
        ],
        "title": "CPU Usage",
        "title_size": "16",
        "title_align": "left",
        "show_legend": true
      },
      "graph_size": "xl"
    }
  },
  {
    "type": "notebook_cells",
    "attributes": {
      "definition": {
        "type": "markdown",
        "text": "# Latency\n\nP99 latency for the service."
      }
    }
  },
